{
  "name": "@cosrx/core",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.50",
  "description": "Promise based HTTP client built on Fetch with retries, interceptors, cancellation, and request deduplication.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "dev": "rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm run typecheck && npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vinodbiradar09/cosrx.git"
  },
  "keywords": [
    "http",
    "fetch",
    "client",
    "typescript",
    "interceptors",
    "axios"
  ],
  "author": "Vinod Biradar",
  "contributors": [
    "Vinod Biradar (https://github.com/Vinodbiradar09)"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@vitest/coverage-v8": "^4.1.4",
    "rollup": "^4.34.9",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.8.1",
    "vitest": "^4.1.4"
  }
}
